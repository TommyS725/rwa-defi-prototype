{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": [
      "apps/frontend/**/*.js",
      "apps/frontend/**/*.ts",
      "apps/frontend/**/*.tsx",
      "!apps/frontend/dist",
      "!apps/frontend/dist",
      "!apps/frontend/node_modules",
      "!apps/frontend/node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUnusedImports": "error"
      }
    }
  }
}
