{
  "$schema": "https://biomejs.dev/schemas/2.3.7/schema.json",
  "files": {
    "includes": [
      "apps/frontend/**/*.js",
      "apps/frontend/**/*.ts",
      "apps/frontend/**/*.tsx",
      "!apps/frontend/dist",
      "!apps/frontend/dist/**",
      "!apps/frontend/node_modules",
      "!apps/frontend/node_modules/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": false
  }
}
