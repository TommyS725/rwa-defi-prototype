{
  "name": "rwa-defi-prototype",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "overrides": {
      "@wagmi/connectors": "6.1.4"
    }
  },
  "scripts": {
    "format": "biome format --write",
    "format:check": "biome format",
    "contracts:dev": "pnpm --filter @rwa/contracts dev",
    "contracts:simulate:functions": "pnpm --filter @rwa/contracts simulate:functions",
    "contracts:source:copy": "pnpm --filter @rwa/contracts source:copy",
    "contracts:generate": "pnpm --filter @rwa/contracts generate",
    "oracle-worker:dev": "pnpm --filter @rwa/oracle-worker dev",
    "oracle-worker:deploy": "pnpm --filter @rwa/oracle-worker deploy",
    "web:dev": "pnpm --filter @rwa/frontend dev",
    "web:build": "pnpm --filter @rwa/frontend build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7"
  }
}
